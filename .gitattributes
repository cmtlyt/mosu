# ==========================================
# 1. 全局默认策略
# ==========================================
# 自动识别文本文件，并在仓库中强制统一转换为 LF
* text=auto eol=lf

# ==========================================
# 2. 强制使用 LF 的文件（防止 Windows 污染）
# ==========================================
# 这些文件如果在 Windows 上变成 CRLF 会导致运行报错
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
.env* text eol=lf
*.svg text eol=lf

# ==========================================
# 3. 强制使用 CRLF 的文件（仅限 Windows 专属）
# ==========================================
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ==========================================
# 4. 二进制文件（绝对不要修改它们的换行符）
# ==========================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
