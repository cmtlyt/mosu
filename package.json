{
  "name": "@cmtlyt/mosu",
  "version": "0.1.0",
  "private": true,
  "files": [
    "dist-npm"
  ],
  "type": "module",
  "exports": {
    "./animation-sdk": {
      "import": "./dist-npm/animation-sdk.mjs",
      "require": "./dist-npm/animation-sdk.cjs",
      "types": "./dist-npm/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:npm": "vite build --config vite.config.npm.ts",
    "preview": "vite preview",
    "lint": "oxlint",
    "lint:github": "oxlint --format=github",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --no-error-on-unmatched-pattern",
    "fmt:check": "oxfmt --no-error-on-unmatched-pattern --check",
    "prepare": "husky"
  },
  "dependencies": {
    "@cmtlyt/lingshu-toolkit": "^0.10.0",
    "@cmtlyt/logger": "^0.6.1",
    "@mlc-ai/web-llm": "^0.2.84",
    "@tanstack/react-router": "^1.170.15",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260612.1",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "changelogithub": "^14.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^4.5.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm run fmt",
      "pnpm run lint"
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
