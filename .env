# Mosu Server Configuration
# 复制此文件为 .env.local 并修改配置（.env.local 会被 git 忽略）

# Server Settings
PORT=3000
HOST=0.0.0.0

# AI Configuration
# AI_BASE_URL is required for chat functionality
# Example: https://api.openai.com/v1
AI_BASE_URL=

# AI API key (required if AI_BASE_URL is set)
AI_API_KEY=


# AI model name
AI_MODEL=qwen-max